    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/swagger": "^8.1.1",
    "@okvns/application": "workspace:*",
    "@okvns/domain": "workspace:*",
    "@okvns/shared": "workspace:*",
    "@okvns/yaml": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express": "^4.21.0",
    "mysql2": "^3.11.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.4",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.4",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "typescript": "^5.6.2",
    "unplugin-swc": "^1.5.1",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^3.2.6"
