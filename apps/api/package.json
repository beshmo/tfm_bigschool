{
  "name": "@okvns/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "migrate": "node scripts/migrate.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
