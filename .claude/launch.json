{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api-memory",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@okvns/api", "run", "start:dev"],
      "env": { "OKVNS_STORAGE_DRIVER": "memory" },
      "port": 3000
    },
    {
      "name": "admin-web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@okvns/admin-web", "run", "dev"],
      "port": 5173
    },
    {
      "name": "demo-web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@okvns/demo-web", "run", "dev"],
      "port": 5174
    }
  ]
}
